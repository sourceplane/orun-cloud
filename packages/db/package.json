{
  "name": "@saas/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./manifest": "./src/manifest.ts",
    "./types": "./src/types.ts",
    "./ids": "./src/ids/index.ts",
    "./hyperdrive": "./src/hyperdrive/index.ts",
    "./identity": "./src/identity/index.ts",
    "./membership": "./src/membership/index.ts",
    "./events": "./src/events/index.ts",
    "./projects": "./src/projects/index.ts",
    "./config": "./src/config/index.ts",
    "./webhooks": "./src/webhooks/index.ts",
    "./metering": "./src/metering/index.ts",
    "./billing": "./src/billing/index.ts",
    "./notifications": "./src/notifications/index.ts",
    "./support": "./src/support/index.ts",
    "./integrations": "./src/integrations/index.ts",
    "./work": "./src/work/index.ts",
    "./work/model": "./src/work/model.ts",
    "./work/autolink": "./src/work/autolink.ts",
    "./work/delivery": "./src/work/delivery.ts",
    "./work/ingest": "./src/work/ingest.ts",
    "./work/webhook": "./src/work/webhook.ts",
    "./work/sync": "./src/work/sync.ts",
    "./work/sync-client": "./src/work/sync-client.ts",
    "./work/sync-server": "./src/work/sync-server.ts",
    "./resources": "./src/resources/index.ts",
    "./resources/model": "./src/resources/model.ts",
    "./state": "./src/state/index.ts",
    "./bridge": "./src/bridge/index.ts",
    "./runner": "./src/runner/index.ts"
  },
  "bin": {
    "db-migrate": "./dist/runner/cli.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json && cp -r src/migrations dist/",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "migrate:plan": "node --loader ts-node/esm src/runner/cli.ts plan",
    "migrate:apply": "node --loader ts-node/esm src/runner/cli.ts apply",
    "gen:migrations-lock": "node scripts/gen-migrations-lock.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1067.0",
    "pg": "^8.21.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@saas/eslint-config": "workspace:*",
    "@saas/tsconfig": "workspace:*",
    "@types/pg": "^8.20.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
