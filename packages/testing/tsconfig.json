{
  "extends": "../../tooling/tsconfig/base.json",
  "compilerOptions": {
    // Imported contracts sources use web globals (URL, TextEncoder) that the
    // base ES2022 lib doesn't declare; workers get them from workers-types.
    "lib": ["ES2022", "DOM"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
