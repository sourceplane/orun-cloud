{
  "name": "@saas/chat-worker-tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260612.1",
    "@saas/eslint-config": "workspace:*",
    "@saas/tsconfig": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.43",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@saas/contracts": "workspace:*",
    "@saas/db": "workspace:*",
    "@saas/mcp": "workspace:*",
    "@saas/sdk": "workspace:*"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1",
      "^@saas/contracts$": "<rootDir>/../../packages/contracts/src/index.ts",
      "^@saas/contracts/(.*)$": "<rootDir>/../../packages/contracts/src/$1.ts",
      "^@saas/mcp$": "<rootDir>/../../packages/mcp/src/index.ts",
      "^@saas/sdk$": "<rootDir>/../../packages/sdk/src/index.ts",
      "^@chat-worker/(.*)$": "<rootDir>/../../apps/chat-worker/src/$1.ts",
      "^@saas/db$": "<rootDir>/../../packages/db/src/index.ts",
      "^@saas/db/(.*)$": "<rootDir>/../../packages/db/src/$1/index.ts"
    },
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": {
            "lib": [
              "ES2022",
              "DOM",
              "DOM.Iterable"
            ]
          }
        }
      ]
    },
    "testMatch": [
      "<rootDir>/src/**/*.test.ts"
    ]
  }
}