{
  "extends": "../../tooling/tsconfig/base.json",
  "compilerOptions": {
    "types": ["jest", "node", "@cloudflare/workers-types"],
    "allowSyntheticDefaultImports": true,
    "composite": false,
    "incremental": false,
    "declaration": false,
    "declarationMap": false,
    "baseUrl": ".",
    "paths": {
      "@saas/contracts": ["../../packages/contracts/src/index.ts"],
      "@saas/contracts/*": ["../../packages/contracts/src/*.ts"],
      "@saas/db": ["../../packages/db/src/index.ts"],
      "@saas/db/hyperdrive": ["../../packages/db/src/hyperdrive/index.ts"],
      "@saas/db/support": ["../../packages/db/src/support/index.ts"],
      "@saas/db/events": ["../../packages/db/src/events/index.ts"],
      "@admin-worker/*": ["../../apps/admin-worker/src/*.ts"]
    }
  },
  "include": ["src/**/*.ts", "../../apps/admin-worker/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
