# pnpm install hardening for CI (and local dev).
#
# Bound network behaviour so a slow or stalling registry retries and then
# fails fast instead of hanging. A runaway `pnpm install` previously ran for
# ~60 min in CI before erroring; these limits cap per-request time and retries
# so a flaky registry can no longer stall an install indefinitely.
fetch-retries=3
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000
fetch-timeout=60000

# Resolve from the content-addressed store first and only reach the registry
# for packages that are genuinely missing. Combined with the CI pnpm-store
# cache this keeps installs warm and minimises registry round-trips.
prefer-offline=true
