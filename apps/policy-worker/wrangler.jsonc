{
  "name": "policy-worker",
  "compatibility_date": "2025-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/index.ts",
  "minify": false,
  "vars": {
    "ENVIRONMENT": "local"
  },
  "env": {
    "dev": {
      "vars": { "ENVIRONMENT": "dev" }
    },
    "stage": {
      "workers_dev": false,
      "vars": { "ENVIRONMENT": "stage" }
    },
    "prod": {
      "workers_dev": false,
      "vars": { "ENVIRONMENT": "prod" }
    }
  }
}
