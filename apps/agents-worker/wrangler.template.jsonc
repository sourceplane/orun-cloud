// Rendered to wrangler.jsonc by tooling/wire/render.mjs (BF6 deploy-time wiring).
// Resource IDs are NEVER committed: @@wiring(<component>/<env>:<key>)@@ tokens are
// resolved from AWS Secrets Manager at deploy time (wire-live) or from the
// committed wiring.fixture.json for offline dry-runs (wire-fixture).
//
// AG6 control plane: workspace routes + the lease-sweep cron; the scheduled
// handler no-ops when PLATFORM_DB/downstream bindings are absent.
{
  "name": "agents-worker",
  "compatibility_date": "2025-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/index.ts",
  "minify": false,
  "vars": {
    "ENVIRONMENT": "local"
  },
  // The per-session attach relay (saas-agents-live AL6): one SQLite-backed DO
  // per session. DO bindings are NOT inherited by named environments, so the
  // block is repeated per env; the migration is top-level.
  "durable_objects": {
    "bindings": [{ "name": "SESSION_RELAY", "class_name": "SessionRelay" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["SessionRelay"] }],
  "env": {
    "dev": {
      "vars": {
        "ENVIRONMENT": "dev"
      },
      "durable_objects": {
        "bindings": [{ "name": "SESSION_RELAY", "class_name": "SessionRelay" }]
      }
    },
    "stage": {
      "workers_dev": false,
      "vars": {
        "ENVIRONMENT": "stage"
      },
      "durable_objects": {
        "bindings": [{ "name": "SESSION_RELAY", "class_name": "SessionRelay" }]
      },
      // Lease sweep (design §4.3): reclaim lapsed sessions + destroy sandboxes.
      "triggers": {
        "crons": ["*/5 * * * *"]
      },
      "hyperdrive": [
        {
          "binding": "PLATFORM_DB",
          "id": "@@wiring(cloudflare-hyperdrive/stage:hyperdrive_id)@@"
        }
      ],
      "services": [
        {
          "binding": "MEMBERSHIP_WORKER",
          "service": "membership-worker-stage"
        },
        {
          "binding": "POLICY_WORKER",
          "service": "policy-worker-stage"
        },
        {
          "binding": "CONFIG_WORKER",
          "service": "config-worker-stage"
        },
        {
          "binding": "IDENTITY_WORKER",
          "service": "identity-worker-stage"
        },
        {
          "binding": "BILLING_WORKER",
          "service": "billing-worker-stage"
        },
        {
          "binding": "METERING_WORKER",
          "service": "metering-worker-stage"
        }
      ]
    },
    "prod": {
      "workers_dev": false,
      "vars": {
        "ENVIRONMENT": "prod"
      },
      "durable_objects": {
        "bindings": [{ "name": "SESSION_RELAY", "class_name": "SessionRelay" }]
      },
      "triggers": {
        "crons": ["*/5 * * * *"]
      },
      "hyperdrive": [
        {
          "binding": "PLATFORM_DB",
          "id": "@@wiring(cloudflare-hyperdrive/prod:hyperdrive_id)@@"
        }
      ],
      "services": [
        {
          "binding": "MEMBERSHIP_WORKER",
          "service": "membership-worker-prod"
        },
        {
          "binding": "POLICY_WORKER",
          "service": "policy-worker-prod"
        },
        {
          "binding": "CONFIG_WORKER",
          "service": "config-worker-prod"
        },
        {
          "binding": "IDENTITY_WORKER",
          "service": "identity-worker-prod"
        },
        {
          "binding": "BILLING_WORKER",
          "service": "billing-worker-prod"
        },
        {
          "binding": "METERING_WORKER",
          "service": "metering-worker-prod"
        }
      ]
    }
  }
}
